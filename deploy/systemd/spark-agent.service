[Unit]
Description=Spark Signals host telemetry agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=spark-signals
Group=spark-signals
EnvironmentFile=-/etc/spark-signals/agent.env
ExecStart=/usr/local/bin/spark-agent --site home --node %H
Restart=on-failure
RestartSec=5

NoNewPrivileges=yes
PrivateTmp=yes
ProtectHome=yes
ProtectSystem=strict
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes
RestrictSUIDSGID=yes
LockPersonality=yes
MemoryDenyWriteExecute=yes
ReadOnlyPaths=/proc
ReadOnlyPaths=/sys

[Install]
WantedBy=multi-user.target

