[Unit]
Description=Spark Signals host telemetry agent (prototype)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=%h/projects/spark-signals/target/release/spark-agent --stdout --site home --node %H
Restart=on-failure
RestartSec=5

NoNewPrivileges=yes
PrivateTmp=yes
ProtectHome=read-only
ProtectSystem=strict
LockPersonality=yes
MemoryDenyWriteExecute=yes
ReadOnlyPaths=/proc
ReadOnlyPaths=/sys

[Install]
WantedBy=default.target
